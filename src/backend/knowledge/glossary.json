        "tr": "Ayrımcılık"
      }
    },
    {
      "term": "Human Rights Due Diligence",
      "short_definition": "The process through which enterprises identify, prevent, mitigate, and account for how they address their adverse human rights impacts.",
      "related_standards": ["OECD Guidelines", "UN Guiding Principles", "EU CSDDD"],
      "translations": {
