      "related_standards": ["ILO Convention 29", "ILO Convention 105"],
      "translations": {
        "es": "Trabajo forzoso",
        "fr": "Travail forcé",
        "de": "Zwangsarbeit",
        "pt": "Trabalho forçado",
        "ar": "العمل القسري",
        "tr": "Zorla çalıştırma"
      }
    },
    {
      "term": "Child Labour",
